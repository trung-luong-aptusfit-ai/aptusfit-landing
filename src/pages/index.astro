---
import Base from "@/layouts/Base.astro";
import HeroSection from "@/components/HeroSection";
---

<Base
  title="AptusFIT — Training that adapts to you"
  description="AptusFIT is a training system that adapts as you do. It uses your real workout data to adjust your plan over time, so you don't have to constantly rethink what to do next. No noise, no hype; just steady, long term progress!"
  isLandingPage={true}
>
  <meta slot="head" name="theme-color" content="#0096ff" />

  <div class="min-h-screen flex flex-col">
    <!-- Hero Section with Animations -->
    <HeroSection client:load />

    <!-- Footer -->
    <footer class="py-10 mt-auto border-t border-border bg-background">
      <div class="max-w-[1200px] mx-auto px-5">
        <div class="flex flex-col items-center gap-4">
          <p class="text-sm m-0">
            <a href="mailto:Contact@AptusFIT.ai" class="text-accent hover:text-accent/80 transition-colors underline font-medium">
              Contact Us
            </a>
          </p>
          <div class="flex items-center gap-4 text-sm text-muted-foreground">
            <a href="/policy" class="hover:text-foreground transition-colors">Privacy Policy</a>
            <span>·</span>
            <a href="/terms" class="hover:text-foreground transition-colors">Terms of Service</a>
          </div>
          <p class="text-center text-sm text-muted-foreground m-0">
            © 2026 AptusFIT Pte. Ltd. a Singapore Registered Company with Registration No. 202547602D
          </p>
        </div>
      </div>
    </footer>
  </div>
</Base>
